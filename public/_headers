# Cache-Control for static assets.
# Note: GitHub Pages does not honour _headers (it sets its own caching for
# hashed assets). This file takes effect on hosts that support it (Netlify,
# Cloudflare Pages, etc.).

# Hashed, content-addressed build output — safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Large, stable 3D + decoder assets.
/models/*
  Cache-Control: public, max-age=31536000, immutable
/draco/*
  Cache-Control: public, max-age=31536000, immutable

# Images and PDF — long but revalidatable.
/images/*
  Cache-Control: public, max-age=2592000
/*.pdf
  Cache-Control: public, max-age=2592000

# HTML entry — always revalidate so new deploys are picked up.
/index.html
  Cache-Control: public, max-age=0, must-revalidate
